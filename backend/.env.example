# Backend Environment Variables (.env.example)
# DO NOT commit sensitive values (.env) to GitHub
# Use this file as a reference - copy to .env and fill in real values

# ═══════════════════════════════════════════════════════════════════════════════
# SERVER & DATABASE
# ═══════════════════════════════════════════════════════════════════════════════

# Server Port (default: 5000)
PORT=5000

# Environment (development or production)
NODE_ENV=development

# MongoDB Connection String
# ⚠️ SENSITIVE - Never commit real credentials
# Format: mongodb+srv://username:password@cluster.mongodb.net/database?retryWrites=true&w=majority
# Get from: https://www.mongodb.com/cloud/atlas
MONGODB_URI=mongodb+srv://harshadkumarbommisetty_db_user:roop123@ac-mqofbcg-shard-00-00.pvjycli.mongodb.net:27017,ac-mqofbcg-shard-00-01.pvjycli.mongodb.net:27017,ac-mqofbcg-shard-00-02.pvjycli.mongodb.net:27017/?ssl=true&replicaSet=atlas-10fezh-shard-0&authSource=admin&appName=Cluster0

# ═══════════════════════════════════════════════════════════════════════════════
# AUTHENTICATION (JWT)
# ═══════════════════════════════════════════════════════════════════════════════

# JWT Secret - Use a strong random string in production
# ⚠️ SENSITIVE - Change this in production
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production-12345

# How long JWT tokens are valid for (default: 7d)
JWT_EXPIRES_IN=7d

# ═══════════════════════════════════════════════════════════════════════════════
# FRONTEND URL (for CORS & Email Links)
# ═══════════════════════════════════════════════════════════════════════════════

# Where the frontend is deployed
# Used for:
# 1. CORS origin validation
# 2. Email notification links (so users can click to view notices)
#
# Development:  http://localhost:5173
# Production:   https://your-app.vercel.app
FRONTEND_URL=http://localhost:5173

# ═══════════════════════════════════════════════════════════════════════════════
# EMAIL CONFIGURATION (Notice Alerts)
# ═══════════════════════════════════════════════════════════════════════════════

# Email Service Provider (gmail, sendgrid, custom, or leave blank for testing)
EMAIL_SERVICE=gmail

# ─── GMAIL Configuration ────────────────────────────────────────────────────────
# RECOMMENDED: Use Gmail for small-scale deployments
# 
# Setup Instructions:
# 1. Go to: https://myaccount.google.com/security
# 2. Enable 2-Step Verification
# 3. Go to: https://myaccount.google.com/apppasswords
# 4. Select "Mail" and "Windows Computer" (or your device)
# 5. Copy the 16-character password
# 6. Paste it in EMAIL_PASSWORD below (no spaces)

# Gmail account email
EMAIL_USER=noticeboard.dnb@gmail.com

# 16-character App Password (from step 5 above)
# ⚠️ SENSITIVE - This is NOT your regular Gmail password
# Generate new one at: https://myaccount.google.com/apppasswords
EMAIL_PASSWORD=kdnsbxdovxufnoma

# From email address (what users see as sender)
EMAIL_FROM=noticeboard.dnb@gmail.com

# ─── Alternative: Custom SMTP Server ─────────────────────────────────────────
# Uncomment and fill these if using your organization's email server instead:
# EMAIL_SERVICE=custom
# SMTP_HOST=smtp.yourcompany.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your-email@yourcompany.com
# SMTP_PASSWORD=your-password
# EMAIL_FROM=noreply@noticeboard.com

# ─── Testing: Ethereal (No Real Emails) ──────────────────────────────────────
# Leave EMAIL_SERVICE blank to use Ethereal
# Emails will log preview URLs to console (no real sending)

# ═══════════════════════════════════════════════════════════════════════════════
# RATE LIMITING (Optional - Recommended for Production)
# ═══════════════════════════════════════════════════════════════════════════════

# Global rate limit window (milliseconds)
# RATE_LIMIT_WINDOW_MS=900000

# Max requests per window
# RATE_LIMIT_MAX_REQUESTS=200

# Max login attempts per window
# RATE_LIMIT_LOGIN_MAX=20
