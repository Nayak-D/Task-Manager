# Frontend Environment Variables (.env.example)
# DO NOT commit sensitive values to GitHub
# COPY this file to .env.local for local development

# ─── API Configuration ──────────────────────────────────────────────────────────
# The backend API URL - This MUST match where your backend is deployed
#
# Development (local): http://localhost:5000/api
# Production (Vercel):  https://your-backend-domain.com/api
#
# For Vercel deployment, set this in Vercel project settings as an env variable
VITE_API_URL=http://localhost:5000/api
